# =========================
# Elasticsearch
# =========================

# If running backend INSIDE Docker → use es-sandbox
# If running backend LOCALLY → use localhost

ES_HOST=http://localhost:9200
#ES_HOST=http://es-sandbox:9200

ES_USERNAME=
ES_PASSWORD=
ES_INDEX=gkg_sandbox
ES_VERIFY_SSL=false


# =========================
# LLM
# =========================

LLM_BASE_URL=http://xxx.xxx.xxx.xxx:xxxx/v1
LLM_MODEL_NAME=openai/MiniMax-M2.1-AWQ
LLM_API_KEY=not-required
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=60


# =========================
# Schema Context
# =========================

SCHEMA_CONTEXT_PATH=team_a_dspy/data/schema_context.txt


# =========================
# (Optional) ChromaDB
# =========================

# Uncomment only if using ChromaDB server mode

# CHROMA_HOST=chromadb
# CHROMA_PORT=8000
# CHROMA_SSL=false
# CHROMA_COLLECTION=gkg_mapping
# SCHEMA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# SCHEMA_SEARCH_K=8


# =========================
# Agent / Query Limits
# =========================

AGENT_MAX_ITERATIONS=15
QUERY_MAX_ATTEMPTS=3
MAX_RESULT_DOCS=20
MAX_AGG_BUCKETS=100
MAX_VALIDATION_CANDIDATES=50